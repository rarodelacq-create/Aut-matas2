import tkinter as tk   # Importa tkinter para crear ventanas y elementos gráficos
import random          # Importa random para elegir colores al azar

# Ventana principal
root = tk.Tk()   # Crea la ventana principal del programa

root.attributes("-fullscreen", True)  
# Hace que la ventana ocupe toda la pantalla

root.configure(bg="blue", cursor="none")  
# Cambia el color de fondo a azul y oculta el cursor del mouse

# Canvas a pantalla completa
canvas = tk.Canvas(root, bg="blue", highlightthickness=0)
# Crea una zona de dibujo llamada canvas con fondo azul

canvas.pack(fill="both", expand=True)
# Hace que el canvas ocupe toda la ventana

root.update()  
# Actualiza la ventana para obtener tamaños reales

SCREEN_W = canvas.winfo_width()
# Guarda el ancho de la pantalla

SCREEN_H = canvas.winfo_height()
# Guarda el alto de la pantalla

# Cargar imagen
imagen = tk.PhotoImage(file="logo2.png")
# Carga la imagen llamada "logo2.png"

# Crear imagen en el canvas
img = canvas.create_image(
    SCREEN_W // 2,   # Posición horizontal en el centro
    SCREEN_H // 2,   # Posición vertical en el centro
    image=imagen     # Imagen que se mostrará
)

# Velocidad
dx, dy = 6, 6
# Define la velocidad del movimiento en X y en Y

salida_activa = False
# Controla cuándo se puede cerrar el programa

inactivo = True  
# Al inicio la imagen no se mueve

# Colores disponibles
colores = ["blue", "red", "green", "purple", "black", "orange", "cyan", "pink"]
# Lista de colores posibles para el fondo

def cambiar_color():
    # Elige un color al azar
    color = random.choice(colores)

    # Cambia el color de la ventana
    root.configure(bg=color)

    # Cambia el color del canvas
    canvas.configure(bg=color)

def activar_movimiento():
    global inactivo
    # Permite que la imagen comience a moverse
    inactivo = False

def mover():
    global dx, dy

    # Solo se mueve si ya no está inactivo
    if not inactivo:

        # Mueve la imagen
        canvas.move(img, dx, dy)

        # Obtiene los bordes de la imagen
        x1, y1, x2, y2 = canvas.bbox(img)

        # Rebote en lados izquierdo y derecho
        if x1 <= 0 or x2 >= SCREEN_W:

            # Cambia la dirección horizontal
            dx = -dx

            # Cambia el color del fondo
            cambiar_color()

        # Rebote arriba y abajo
        if y1 <= 0 or y2 >= SCREEN_H:

            # Cambia la dirección vertical
            dy = -dy

            # Cambia el color del fondo
            cambiar_color()

    # Repite la función cada 30 milisegundos
    root.after(30, mover)

def activar_salida():
    global salida_activa

    # Permite cerrar el programa
    salida_activa = True

def cerrar(event):

    # Si ya está permitida la salida
    if salida_activa:

        # Cierra la ventana
        root.destroy()

# ⏱ 6 segundos inactivo
root.after(6000, activar_movimiento)
# Espera 6 segundos antes de mover la imagen

# ⏱ 2 segundos para permitir salida
root.after(2000, activar_salida)
# Espera 2 segundos antes de permitir cerrar el programa

root.bind("<Motion>", cerrar)
# Detecta movimiento del mouse para cerrar la ventana

mover()
# Inicia el movimiento

root.mainloop()
# Mantiene la ventana abierta y funcionando
